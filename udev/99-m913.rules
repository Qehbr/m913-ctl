# Redragon M913 Impact Elite — udev rule for non-root USB access

# 2.4G wireless receiver (VID 25a7, PID fa07)
SUBSYSTEMS=="usb", ATTRS{idVendor}=="25a7", ATTRS{idProduct}=="fa07", MODE="0666"
# Wired / dual-mode USB (VID 25a7, PID fa08)
SUBSYSTEMS=="usb", ATTRS{idVendor}=="25a7", ATTRS{idProduct}=="fa08", MODE="0666"
